body{
font-family:Arial;
text-align:center;
background:linear-gradient(to right,#1e3c72,#2a5298);
color:white;
padding:50px;
}

h2{
font-size:40px;
}

input{
padding:10px;
font-size:18px;
border-radius:5px;
border:none;
}

button{
padding:10px 20px;
font-size:18px;
background:#ffcc00;
border:none;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#ffaa00;
}

#result{
margin-top:20px;
font-size:22px;
}
